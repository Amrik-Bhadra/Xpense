generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider  = "postgresql"
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum OtpPurpose {
  REGISTER
  RESET_PASSWORD
}

model User {
  id            String        @id @default(cuid())
  name          String
  email         String        @unique
  password      String
  emailVerified DateTime?
  transactions  Transaction[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Otp {
  id         String     @id @default(cuid())
  email      String
  codeHash   String
  purpose    OtpPurpose
  expiresAt  DateTime
  consumedAt DateTime?
  attempts   Int        @default(0)
  createdAt  DateTime   @default(now())

  @@index([email, purpose])
}

model Category {
  id           String        @id @default(cuid())
  name         String        @unique
  transactions Transaction[]
  createdAt    DateTime      @default(now())
}

model Transaction {
  id         String           @id @default(cuid())
  title      String
  amount     Float
  type       TransactionType  @default(EXPENSE)
  notes      String?
  category   Category         @relation(fields: [categoryId], references: [id])
  categoryId String
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@index([userId])
  @@index([userId, type])
}