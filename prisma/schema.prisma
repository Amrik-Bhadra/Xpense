generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider  = "postgresql"
}

model Category {
  id         String    @id @default(cuid())
  name       String    @unique
  expense    Expense[]
  createdAt  DateTime  @default(now())
}

model Expense {
  id         String     @id @default(cuid())
  title      String
  amount     Float
  notes      String?
  category   Category   @relation(fields: [categoryId], references: [id])
  categoryId String
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}